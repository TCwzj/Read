# ===========================================
# 大模型配置 (LLM) - 核心配置
# ===========================================

# LLM 提供商选择：openai, azure, anthropic, gemini, ollama, localapi
LLM_PROVIDER=openai

# API Key (根据提供商填写)
LLM_API_KEY=your-api-key-here

# 自定义 API 端点 (可选，用于兼容 OpenAI 的 API 或其他服务)
# 示例：https://api.openai.com/v1
# 示例：http://localhost:11434/v1 (Ollama)
# 示例：https://dashscope.aliyuncs.com/compatible-mode/v1 (通义千问)
LLM_API_BASE=

# Azure API 版本 (仅 Azure 需要)
LLM_API_VERSION=2024-02-15-preview

# 模型名称
LLM_MODEL_NAME=gpt-4o

# 生成参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# 备用模型 (可选)
LLM_FALLBACK_MODEL=

# 请求配置
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3


# ===========================================
# TTS 语音合成配置
# ===========================================

# TTS 提供商选择：edge (免费), azure, aliyun, chattts, openai
TTS_PROVIDER=edge

# API Key (部分提供商需要)
TTS_API_KEY=

# 自定义 API 端点
TTS_API_BASE=

# 语音配置
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_SPEED=1.0
TTS_PITCH=0

# 输出配置
TTS_FORMAT=mp3
TTS_SAMPLE_RATE=24000


# ===========================================
# 图片生成配置
# ===========================================

# 图片生成提供商：stable_diffusion, dall-e, midjourney, comfiui, local
IMAGE_PROVIDER=stable_diffusion

# API Key (部分提供商需要)
IMAGE_API_KEY=

# API 端点 (SD WebUI 默认地址)
IMAGE_API_BASE=http://localhost:7860

# 生成配置
IMAGE_MODEL=sd_xl_base_1.0.safetensors
IMAGE_WIDTH=1920
IMAGE_HEIGHT=1080
IMAGE_STEPS=30
IMAGE_CFG_SCALE=7.0

# 风格一致性配置
IMAGE_USE_IP_ADAPTER=true
IMAGE_USE_CONTROLNET=false
IMAGE_FIXED_SEED=42

# 批处理配置
IMAGE_BATCH_SIZE=4
IMAGE_CONCURRENT_JOBS=2


# ===========================================
# 视频合成配置
# ===========================================

VIDEO_CODEC=libx264
AUDIO_CODEC=aac
VIDEO_CRF=23
VIDEO_PRESET=medium
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30
FFMPEG_PATH=ffmpeg


# ===========================================
# 新闻抓取配置
# ===========================================

SCRAPER_HEADLESS=true
SCRAPER_PROXY=
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
SCRAPER_DELAY=1.0
SCRAPER_MAX_RETRIES=3
SCRAPER_TIMEOUT=30000


# ===========================================
# 流水线配置
# ===========================================

STORAGE_ROOT=./storage
PIPELINE_MAX_NEWS=10
PIPELINE_TARGET_SCENES=1800
PIPELINE_TARGET_LENGTH=30000
PIPELINE_QUALITY_CHECK=true
PIPELINE_MIN_IMAGE_QUALITY=0.6